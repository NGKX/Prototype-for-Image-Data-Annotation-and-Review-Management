# ============================================
# DataLens 标注平台 — 环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================

# --- 数据库 (PostgreSQL) ---
# Docker 部署时 HOST 必须用 postgres（服务名）
POSTGRES_USER=anno_admin
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=annotation_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
# Docker 部署时 HOST 必须用 redis
REDIS_HOST=redis
REDIS_PORT=6379

# --- MinIO (对象存储) ---
# Docker 部署时 HOST 必须用 minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_to_a_strong_password
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_BUCKET=annotation-images

# --- JWT 认证 ---
# 生产环境务必改成随机字符串！
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- 应用 ---
APP_ENV=production
DEBUG=false
# CORS: 改成你的域名，多个用逗号分隔
CORS_ORIGINS=["http://localhost","http://127.0.0.1"]

# --- ML 服务 (可选) ---
ML_SERVICE_URL=http://ml-service:8001
ML_SERVICE_TIMEOUT=30

# --- 数据导出限制 ---
MAX_EXPORT_SIZE_GB=2
MAX_EXPORT_IMAGES=5000
EXPORT_RETENTION_DAYS=7
